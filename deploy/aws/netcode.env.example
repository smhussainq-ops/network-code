# Netcode control-plane pilot environment
# Copy to your ECS task definition / Secrets Manager values.

NETCODE_WORKSPACE=/data
NETCODE_ENV=production
NETCODE_EXECUTION=runner
NETCODE_RUNNER_POOL=pilot
NETCODE_REQUIRE_APPROVAL=true
NETCODE_AUTH=1
NETCODE_LICENSE_ENFORCEMENT=true
NETCODE_ALLOWED_HOSTS=netcode.example.com

# ECS injects the RDS username/password as separate Secrets Manager values.
# DATABASE_URL remains supported for non-ECS deployments.
NETCODE_DATABASE_HOST=netcode-rds.cluster-xxxx.us-east-1.rds.amazonaws.com
NETCODE_DATABASE_PORT=5432
NETCODE_DATABASE_NAME=netcode
NETCODE_DATABASE_USER=replace-with-secret-manager-value
NETCODE_DATABASE_PASSWORD=replace-with-secret-manager-value
NETCODE_DATABASE_SSLMODE=verify-full

# The Rez backend calls this bridge token when it needs runner-backed reads.
# Store the real value in AWS Secrets Manager.
NETCODE_REZ_BRIDGE_TOKEN=replace-with-secret-manager-value

# Rez licensing and failed-verification handoff use separate service credentials.
NETCODE_ENTITLEMENT_URL=http://rez.internal:8080/api/license/platform-entitlements
NETCODE_ENTITLEMENT_TOKEN=replace-with-secret-manager-value
NETCODE_REZ_TRIGGER_URL=http://rez.internal:8080
NETCODE_REZ_TRIGGER_TOKEN=replace-with-secret-manager-value
NETCODE_REZ_ENVIRONMENT_ID=replace-with-customer-environment-id

# Auth must be explicitly bootstrapped for production pilots.
NETCODE_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
NETCODE_BOOTSTRAP_ADMIN_PASSWORD=replace-with-secret-manager-value
